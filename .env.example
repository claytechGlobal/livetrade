# ---- Core ----
PORT=3000
NODE_ENV=production
# Long random string used to sign login cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
# First-run admin login (you can change both later in Settings → Access & Security)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Subscription gate: set "false" to let any access code in (testing).
# Set back to "true" when you want users to must purchase first.
REQUIRE_SUBSCRIPTION=false

# ---- Database ----
# Local: leave unset (uses ./data.sqlite next to the app).
# CRITICAL on Vercel: /tmp SQLite is WIPED on every cold start — clients lose dashboard
# data and access-code emails can send twice. Do NOT rely on Vercel /tmp for production.
#
# Railway (recommended):
#   1. Add a Volume mounted at /data
#   2. Set DB_PATH=/data/livetrades.sqlite
# Deploy the WHOLE live-trades-backend folder to Railway (UI + API together).
# Then point your domain / APP_URL to the Railway URL. No separate API URL in Vercel needed.
DB_PATH=./data.sqlite
# Client portal auto sign-out (idle + cookie). Default 10 minutes.
CLIENT_SESSION_MS=600000
# Set to "true" once to load demo data (clients, trades, accounts) for testing
SEED_DEMO=false

# Vercel Cron auth (Bearer token for GET /api/cron/daily)
CRON_SECRET=replace-with-random-string

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
# From: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Map each package to its Stripe PRICE id (Dashboard → Products → your price → API id, starts with price_)
PRICE_STARTER=price_xxx
PRICE_PRO=price_yyy
PRICE_ELITE=price_zzz

# ---- Public pricing + checkout links (shown on the login screen) ----
LINK_ACCESS=https://buy.stripe.com/5kQaEX3Q697Q4tJbGmefC0b
LINK_STARTER=https://buy.stripe.com/bJefZh0DUdo60dteSyefC05
LINK_PRO=https://buy.stripe.com/dRm5kD2M24RAd0feSyefC06
LINK_ELITE=https://buy.stripe.com/7sY00j0DUbfYe4j25MefC07
LINK_PRIME=https://buy.stripe.com/cNi8wPaeu2Js2lB5hYefC09
PRICE_ACCESS_LABEL=$45/mo
PRICE_STARTER_LABEL=$500
PRICE_PRO_LABEL=$1000
PRICE_ELITE_LABEL=$1500
PRICE_PRIME_LABEL=$2500

# ---- Email (Resend — planthetrade.co) ----
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM=LIVE TRADES <noreply@planthetrade.co>
APP_URL=https://planthetrade.co
# Where signed contract copies are sent (your inbox). Required for Sign & Submit.
CONTRACT_NOTIFY_EMAIL=you@yourdomain.com

# ---- Daily report schedule (5:00 PM Eastern) ----
DAILY_SEND_ENABLED=true
DAILY_SEND_HOUR=17
DAILY_SEND_TZ=America/New_York
DAILY_SEND_ONLY_WITH_DATA=true
