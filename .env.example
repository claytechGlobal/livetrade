# ---- Core ----
PORT=3000
NODE_ENV=production
# Long random string used to sign login cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
# First-run admin login (you can change both later in Settings → Access & Security)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Subscription gate: set "false" to let any access code in (testing).
# Set back to "true" when you want users to must purchase first.
REQUIRE_SUBSCRIPTION=false

# ---- Database ----
# Path to the SQLite file. Defaults to ./data.sqlite next to server.js
DB_PATH=./data.sqlite
# Set to "true" once to load demo data (clients, trades, accounts) for testing
SEED_DEMO=false

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
# From: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Map each package to its Stripe PRICE id (Dashboard → Products → your price → API id, starts with price_)
PRICE_STARTER=price_xxx
PRICE_PRO=price_yyy
PRICE_ELITE=price_zzz

# ---- Public pricing + checkout links (shown on the login screen) ----
LINK_STARTER=https://buy.stripe.com/bJefZh0DUdo60dteSyefC05
LINK_PRO=https://buy.stripe.com/dRm5kD2M24RAd0feSyefC06
LINK_ELITE=https://buy.stripe.com/7sY00j0DUbfYe4j25MefC07
LINK_PRIME=https://buy.stripe.com/REPLACE_WITH_PRIME_LINK
PRICE_STARTER_LABEL=$99/mo
PRICE_PRO_LABEL=$179/mo
PRICE_ELITE_LABEL=$299/mo

# ---- Email (optional — used to send access codes to clients) ----
# Leave SMTP_HOST blank to disable email; codes will be logged to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=LIVE TRADES <noreply@yourdomain.com>
APP_URL=https://yourdomain.com

# ---- Daily report schedule ----
DAILY_SEND_ENABLED=true
DAILY_SEND_HOUR=17            # 24h clock; 17 = 5 PM
DAILY_SEND_TZ=America/New_York
DAILY_SEND_ONLY_WITH_DATA=true   # only email clients who have P&L uploaded for that day
